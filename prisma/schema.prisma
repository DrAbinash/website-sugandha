generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model ContactSubmission {
  id        String   @id @default(cuid())
  name      String
  phone     String
  email     String?
  subject   String?
  message   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Stores the admin-edited website content as a single JSON blob.
// There is only ever one row, with id = "site".
model SiteSetting {
  id        String   @id
  json      String
  updatedAt DateTime @updatedAt
}
